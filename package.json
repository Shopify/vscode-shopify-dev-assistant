{
  "name": "vscode-shopify-dev-assistant",
  "publisher": "Shopify",
  "displayName": "Shopify Dev Assistant",
  "description": "An AI assistant for developers building on the Shopify platform.",
  "version": "0.0.6",
  "repository": "https://github.com/Shopify/vscode-dev-assistant",
  "engines": {
    "vscode": "^1.95.0"
  },
  "categories": [
    "Other"
  ],
  "icon": "icon.png",
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "chatParticipants": [
      {
        "id": "shopify",
        "fullName": "Shopify",
        "name": "shopify",
        "description": "I'm here to assist you with your app! What can I help you with today?",
        "isSticky": true,
        "disambiguation": [
          {
            "category": "shopify",
            "description": "The user wants to do something with the Shopify developer platform.",
            "examples": [
              "How do I create a new Shopify app?",
              "What are the latest changes in the Shopify GraphQL Admin API?",
              "How do I add a product to a Shopify store?",
              "How do I get the last 10 products from a Shopify store?"
            ]
          }
        ]
      }
    ],
    "commands": [
      {
        "command": "shopify.open-in-graphiql",
        "title": "Open in GraphiQL"
      },
      {
        "command": "shopify.convert-to-graphql",
        "title": "Convert to GraphQL"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "shopify.convert-to-graphql",
          "when": "chatIsEnabled",
          "group": "1_modification"
        }
      ]
    }
  },
  "scripts": {
    "test": "npm run compile && vscode-test",
    "deploy": "vsce publish",
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "lint": "eslint",
    "watch": "tsc -watch -p ./",
    "package": "npm exec vsce package -- --pre-release"
  },
  "devDependencies": {
    "@types/marked": "^6.0.0",
    "@types/mocha": "^10.0.9",
    "@types/node": "20.x",
    "@types/sinon": "^17.0.3",
    "@types/vscode": "^1.95.0",
    "@typescript-eslint/eslint-plugin": "^8.10.0",
    "@typescript-eslint/parser": "^8.7.0",
    "@vscode/test-cli": "^0.0.10",
    "@vscode/test-electron": "^2.4.1",
    "eslint": "^9.13.0",
    "sinon": "^19.0.2",
    "ts-loader": "^9.5.1",
    "typescript": "^5.6.3",
    "vsce": "^2.15.0"
  },
  "dependencies": {
    "@vscode/prompt-tsx": "^0.3.0-alpha.13",
    "eventsource-parser": "^3.0.0",
    "marked": "^15.0.3"
  }
}
